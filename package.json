{
  "name": "mindheal",
  "version": "1.0.0",
  "description": "AI-powered auto-healing agent for Playwright — fixes broken locators, continues tests, and creates PRs automatically",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "mindheal": "./dist/cjs/cli/init.js"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./reporter": {
      "import": "./dist/esm/reporters/heal-reporter.js",
      "require": "./dist/cjs/reporters/heal-reporter.js",
      "types": "./dist/types/reporters/heal-reporter.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "rollup -c rollup.config.mjs --environment BUILD:esm",
    "build:cjs": "rollup -c rollup.config.mjs --environment BUILD:cjs",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "playwright",
    "auto-heal",
    "self-healing",
    "test-automation",
    "locator",
    "ai",
    "testing",
    "e2e",
    "mindheal",
    "enterprise",
    "sap",
    "salesforce",
    "rag",
    "analytics",
    "visual-verification",
    "flaky-test"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "bugs": {
    "url": ""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "dependencies": {
    "express": "^4.18.0",
    "ws": "^8.16.0",
    "ts-morph": "^21.0.0",
    "simple-git": "^3.22.0",
    "open": "^10.0.0",
    "glob": "^10.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "rollup": "^4.9.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
